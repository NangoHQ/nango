{
    "name": "@nangohq/design-system",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "tokens:fetch": "node scripts/tokens-fetch.mjs",
        "tokens:build": "node scripts/tokens-fetch.mjs --build-only",
        "test": "vitest run --config vitest.config.mjs",
        "storybook": "NODE_PATH=./node_modules storybook dev -p 6006",
        "build-storybook": "NODE_PATH=./node_modules storybook build"
    },
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./tokens/tokens.generated.css": "./tokens/tokens.generated.css"
    },
    "dependencies": {
        "@radix-ui/react-slot": "1.2.4",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "lucide-react": "0.542.0",
        "tailwind-merge": "3.6.0"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0"
    },
    "devDependencies": {
        "@storybook/addon-a11y": "10.4.0",
        "@storybook/addon-mcp": "0.6.0",
        "@storybook/addon-themes": "10.4.0",
        "@storybook/react": "10.4.0",
        "@storybook/react-vite": "10.4.0",
        "@tailwindcss/vite": "4.2.0",
        "@tokens-studio/sd-transforms": "2.0.3",
        "@types/react": "18.3.4",
        "@types/react-dom": "18.3.0",
        "prettier": "3.6.2",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "storybook": "10.4.0",
        "style-dictionary": "5.4.1",
        "tailwindcss": "4.2.0",
        "vite": "7.3.2",
        "vitest": "3.2.4"
    }
